ANTHROPIC_API_KEY=sk-ant-xxxxx
ANTHROPIC_MODEL=claude-sonnet-4-6
# Опционально: при наличии /api/chat требует Authorization: Bearer <token>.
# Same-origin защита включена всегда. Этот токен — для серверной интеграции
# (curl, бэкенд-клиенты); веб-UI работает через same-origin без него.
APP_ACCESS_TOKEN=
