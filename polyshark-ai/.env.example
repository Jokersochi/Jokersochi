# ============================================
# PolyShark AI — Environment Variables
# Скопируй в .env и заполни свои значения
# ============================================

# --- Polymarket ---
# Приватный ключ MetaMask кошелька (без 0x)
POLYMARKET_PRIVATE_KEY=your_private_key_here

# RPC endpoint для Polygon (можно взять бесплатно на alchemy.com)
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/your_alchemy_key

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Trading Config ---
# ОБЯЗАТЕЛЬНО true на старте — paper trading без реальных ордеров
DRY_RUN=true

# Стартовый банкролл в USDC
BANKROLL_USDC=500.0

# Порог вероятности для исполнения (Venn-Abers p0 >= threshold)
PROB_THRESHOLD=0.80

# Порог EV для исполнения
EV_THRESHOLD=0.05

# Доля Kelly (0.25 = 1/4 Kelly — рекомендуется)
KELLY_FRACTION=0.25

# Максимальная позиция (% от банкролла)
MAX_POSITION_PCT=0.05

# Минимальный размер ставки в USDC
MIN_BET_USDC=5.0

# --- Model Config ---
# Метод очистки FLB: shin | fl_glm | oo_epc
FLB_METHOD=fl_glm

# Параметр гаммы для FL-GLM (если None — автокалибровка)
FL_GLM_GAMMA=0.05

# Walk-Forward: размер обучающего окна в днях
WF_TRAIN_WINDOW_DAYS=365

# Walk-Forward: размер тестового окна в днях
WF_TEST_WINDOW_DAYS=30

# Embargo: буфер между train и test (дни)
WF_EMBARGO_DAYS=5

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=json

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=change_this_to_random_string
