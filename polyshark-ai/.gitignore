# ============================================
# PolyShark AI — .gitignore
# ============================================

# КРИТИЧЕСКИ ВАЖНО — никогда не коммитить!
.env
*.pem
*.key

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
venv/
env/
.venv/

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# ML модели (могут быть большими — храни в S3/Supabase Storage)
models/*.pkl
models/*.joblib
models/*.cbm
models/*.txt
!models/.gitkeep

# Данные
data/
!data/.gitkeep

# Логи
logs/
*.log

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Coverage
.coverage
htmlcov/
.pytest_cache/
